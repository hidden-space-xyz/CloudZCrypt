<Window
    x:Class="CloudZCrypt.WPF.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:behaviors="clr-namespace:CloudZCrypt.WPF.Behaviors"
    Title="CloudZCrypt"
    Width="800"
    Height="510"
    ResizeMode="NoResize"
    WindowStartupLocation="CenterScreen">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!--  Main Content  -->
        <StackPanel Grid.Row="0">
            <TextBlock FontWeight="Bold" Text="Source Directory:" />
            <DockPanel Margin="0,5,0,0">
                <Button
                    Name="SelectSourceDirectoryButton"
                    Command="{Binding SelectSourceDirectoryCommand}"
                    Content="📂"
                    DockPanel.Dock="Right"
                    IsEnabled="{Binding AreControlsEnabled}" />
                <TextBox
                    x:Name="SourceDirectoryBox"
                    Padding="5"
                    IsEnabled="{Binding AreControlsEnabled}"
                    IsReadOnly="True"
                    Text="{Binding SourceDirectory}" />
            </DockPanel>

            <TextBlock
                Margin="0,20,0,0"
                FontWeight="Bold"
                Text="Destination Directory:" />
            <DockPanel Margin="0,5,0,0">
                <Button
                    Name="SelectDestinationDirectoryButton"
                    Command="{Binding SelectDestinationDirectoryCommand}"
                    Content="📂"
                    DockPanel.Dock="Right"
                    IsEnabled="{Binding AreControlsEnabled}" />
                <TextBox
                    x:Name="DestinationDirectoryBox"
                    Padding="5"
                    IsEnabled="{Binding AreControlsEnabled}"
                    IsReadOnly="True"
                    Text="{Binding DestinationDirectory}" />
            </DockPanel>

            <Grid Grid.Column="0" Margin="0,20,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel
                    Grid.Column="0"
                    Orientation="Vertical">
                    <TextBlock FontWeight="Bold" Text="Encryption Algorithm:" />
                    <ComboBox
                        x:Name="AlgorithmComboBox"
                        Width="200"
                        Margin="0,5,0,0"
                        Padding="5"
                        HorizontalAlignment="Left"
                        IsEnabled="{Binding AreControlsEnabled}"
                        ItemsSource="{Binding AvailableAlgorithms}"
                        SelectedItem="{Binding SelectedAlgorithm}" />
                </StackPanel>

                <StackPanel
                    Grid.Column="2"
                    Orientation="Vertical">
                    <TextBlock FontWeight="Bold" Text="Key Derivation Algorithm:" />
                    <ComboBox
                        x:Name="KeyDerivationAlgorithmComboBox"
                        Width="200"
                        Margin="0,5,0,0"
                        Padding="5"
                        HorizontalAlignment="Left"
                        IsEnabled="{Binding AreControlsEnabled}"
                        ItemsSource="{Binding AvailableKeyDerivationAlgorithms}"
                        SelectedItem="{Binding SelectedKeyDerivationAlgorithm}" />
                </StackPanel>
            </Grid>

            <TextBlock
                Margin="0,20,0,0"
                FontWeight="Bold"
                Text="Password:" />
            <PasswordBox
                x:Name="PasswordBox"
                Height="30"
                Margin="0,5,0,0"
                Padding="5"
                behaviors:PasswordBoxBehavior.Attach="True"
                behaviors:PasswordBoxBehavior.Password="{Binding Password, Mode=TwoWay}"
                IsEnabled="{Binding AreControlsEnabled}" />

            <TextBlock
                Margin="0,20,0,0"
                FontWeight="Bold"
                Text="Confirm Password:" />
            <PasswordBox
                x:Name="ConfirmPasswordBox"
                Height="30"
                Margin="0,5,0,0"
                Padding="5"
                behaviors:PasswordBoxBehavior.Attach="True"
                behaviors:PasswordBoxBehavior.Password="{Binding ConfirmPassword, Mode=TwoWay}"
                IsEnabled="{Binding AreControlsEnabled}" />

        </StackPanel>

        <!--  Action Buttons  -->
        <Grid Grid.Row="1" Margin="0,20,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Button
                x:Name="EncryptButton"
                Grid.Column="1"
                Margin="0,0,5,0"
                Command="{Binding EncryptCommand}"
                Content="{Binding EncryptButtonText}" />
            <Button
                x:Name="DecryptButton"
                Grid.Column="2"
                Margin="5,0,0,0"
                Command="{Binding DecryptCommand}"
                Content="{Binding DecryptButtonText}" />
        </Grid>

        <StackPanel Grid.Row="2">
            <TextBlock
                x:Name="ProgressText"
                HorizontalAlignment="Center"
                FontWeight="SemiBold"
                Text="{Binding ProgressText}"
                Visibility="{Binding ProgressVisibility}" />
            <ProgressBar
                x:Name="ProgressBar"
                Margin="0,5,0,0"
                Visibility="{Binding ProgressVisibility}"
                Value="{Binding ProgressValue}" />
        </StackPanel>

    </Grid>
</Window>