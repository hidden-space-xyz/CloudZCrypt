<Window
    x:Class="CloudZCrypt.WPF.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="CloudZCrypt"
    Width="800"
    Height="450">
    <StackPanel Margin="20">
        <TextBlock Text="Directory to encrypt:" Margin="0,0,0,5"/>
        <DockPanel Margin="0,0,0,15">
            <TextBox x:Name="SourceDirectoryBox" IsReadOnly="True" Width="400"/>
            <Button Content="Select..." Click="SelectSourceDirectory_Click" Margin="5,0,0,0"/>
        </DockPanel>

        <TextBlock Text="Destination directory:" Margin="0,0,0,5"/>
        <DockPanel Margin="0,0,0,15">
            <TextBox x:Name="DestinationDirectoryBox" IsReadOnly="True" Width="400"/>
            <Button Content="Select..." Click="SelectDestinationDirectory_Click" Margin="5,0,0,0"/>
        </DockPanel>

        <TextBlock Text="Encryption algorithm:" Margin="0,0,0,5"/>
        <ComboBox x:Name="AlgorithmComboBox" Width="200" Margin="0,0,0,15"/>

        <TextBlock Text="Password:" Margin="0,0,0,5"/>
        <PasswordBox x:Name="PasswordBox" Width="300" Height="30" Margin="0,0,0,15"/>

        <Button Content="Encrypt" Width="100" Height="30" Click="EncryptButton_Click"/>
    </StackPanel>
</Window>